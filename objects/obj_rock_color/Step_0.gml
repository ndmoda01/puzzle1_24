/// @description Insert description here

if (my_color == noone){
	
	switch(image_index){
		case 0: 
				my_color = #F7D554;
				sprite_index = spr_rock_1x1_Colors_y_2;
		break;
			
		case 1:
				my_color = #C33846;
				sprite_index = spr_rock_1x1_Colors_r_2;
		break;
			
		case 2: 
				my_color = #8DA24E;
				sprite_index = spr_rock_1x1_Colors_g_2;
		break;
			
		case 3: 
				my_color = #5E80B2;
				sprite_index = spr_rock_1x1_Colors_b_2;
		break;
			
		case 4: 
				my_color = #E78C5B;
				sprite_index = spr_rock_1x1_Colors_o_2;
		break;
			
	}
}

